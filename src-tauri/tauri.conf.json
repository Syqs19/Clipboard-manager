{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard Manager",
  "version": "0.2.0",
  "identifier": "com.clipboardmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clipboard Manager",
        "width": 800,
        "height": 600,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2MzZBNDgxM0M5MzI5NzEKUldSeEtaTThnYVEyeGpLVGVBVVNUeUN6SDFiVmN2V0h1SEErRUxvUExGUUplVUdjKzRwRURmMjMK",
      "endpoints": [
        "https://github.com/Syqs19/Clipboard-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
